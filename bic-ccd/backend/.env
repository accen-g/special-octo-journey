APP_NAME=BIC-CCD
APP_VERSION=1.0.0
DEBUG=true
ENV=development
SECRET_KEY=dev-secret-key-change-in-production

# Use SQLite for local development (set to false for Oracle)
USE_SQLITE=false
SQLITE_URL=sqlite:///./bic_ccd.db

# Oracle (used when USE_SQLITE=false)
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE=XEPDB1
DB_USER=bic_ccd
DB_PASSWORD=bic_ccd_pass

DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_SECRET=jwt-secret-change-in-production
JWT_EXPIRE_MINUTES=480

# S3
S3_BUCKET=bic-ccd-evidence
# S3_ENDPOINT=http://localhost:9000   # uncomment for real MinIO/S3
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# Email HTTP service
# EMAIL_SERVICE_URL=https://your-mail-service/mail/send
# EMAIL_FROM_ADDRESS=bic-kri@company.com

# ── Dev mock switches ──────────────────────────────────────────────────────────
# Set to false (and configure the real endpoints above) when ready for live runs.
# These are the ONLY switches needed — no code changes required.
DEV_MOCK_EMAIL=true
DEV_MOCK_S3=true

# ── Seed / demo data ───────────────────────────────────────────────────────────
# true  → insert demo KRIs/users/statuses on first startup (idempotent)
# false → skip all seed inserts; app runs against real/empty data only
SEED_MOCK_DATA=true

# SMTP
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_FROM=bic-ccd@company.com
